<!DOCTYPE html>

<html class="light" lang="en"><head>
<meta charset="utf-8"/>
<meta content="width=device-width, initial-scale=1.0" name="viewport"/>
<title>Register | Chess Academy</title>
<!-- Fonts -->
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&amp;family=Source+Serif+4:wght@600;700&amp;family=JetBrains+Mono:wght@400;500&amp;display=swap" rel="stylesheet"/>
<!-- Material Symbols -->
<link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&amp;display=swap" rel="stylesheet"/>
<link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&amp;display=swap" rel="stylesheet"/>
<!-- Tailwind CSS -->
<script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>
<script id="tailwind-config">
      tailwind.config = {
        darkMode: "class",
        theme: {
          extend: {
            "colors": {
                    "on-secondary-fixed": "#1b1c1c",
                    "on-error": "#ffffff",
                    "inverse-on-surface": "#f1f1f1",
                    "outline": "#7e7576",
                    "primary-container": "#1b1b1b",
                    "surface-tint": "#5e5e5e",
                    "outline-variant": "#cfc4c5",
                    "on-surface": "#1a1c1c",
                    "surface-bright": "#f9f9f9",
                    "on-tertiary": "#ffffff",
                    "tertiary": "#000000",
                    "background": "#f9f9f9",
                    "surface": "#f9f9f9",
                    "on-primary-fixed": "#1b1b1b",
                    "inverse-surface": "#2f3131",
                    "primary-fixed": "#e2e2e2",
                    "on-primary-fixed-variant": "#474747",
                    "on-primary-container": "#848484",
                    "surface-container-low": "#f3f3f3",
                    "on-tertiary-container": "#838484",
                    "surface-container-highest": "#e2e2e2",
                    "secondary-fixed-dim": "#c7c6c6",
                    "on-surface-variant": "#4c4546",
                    "on-secondary": "#ffffff",
                    "error": "#ba1a1a",
                    "surface-container": "#eeeeee",
                    "surface-variant": "#e2e2e2",
                    "surface-container-lowest": "#ffffff",
                    "secondary-container": "#e1dfdf",
                    "secondary": "#5e5e5e",
                    "primary": "#000000",
                    "on-secondary-container": "#626262",
                    "error-container": "#ffdad6",
                    "on-tertiary-fixed-variant": "#454747",
                    "primary-fixed-dim": "#c6c6c6",
                    "tertiary-fixed": "#e2e2e2",
                    "secondary-fixed": "#e4e2e2",
                    "tertiary-container": "#1a1c1c",
                    "on-secondary-fixed-variant": "#464747",
                    "surface-dim": "#dadada",
                    "on-primary": "#ffffff",
                    "tertiary-fixed-dim": "#c6c6c6",
                    "on-tertiary-fixed": "#1a1c1c",
                    "on-error-container": "#93000a",
                    "inverse-primary": "#c6c6c6",
                    "on-background": "#1a1c1c",
                    "surface-container-high": "#e8e8e8"
            },
            "borderRadius": {
                    "DEFAULT": "0.125rem",
                    "lg": "0.25rem",
                    "xl": "0.5rem",
                    "full": "0.75rem"
            },
            "spacing": {
                    "max-width": "1200px",
                    "margin-desktop": "64px",
                    "margin-mobile": "16px",
                    "gutter": "24px",
                    "unit": "4px"
            },
            "fontFamily": {
                    "label-mono": ["JetBrains Mono"],
                    "title-sm": ["Inter"],
                    "body-md": ["Inter"],
                    "headline-md": ["\"Source Serif 4\""],
                    "body-sm": ["Inter"],
                    "headline-md-mobile": ["\"Source Serif 4\""],
                    "display-lg": ["\"Source Serif 4\""]
            },
            "fontSize": {
                    "label-mono": ["12px", {"lineHeight": "16px", "letterSpacing": "0.05em", "fontWeight": "500"}],
                    "title-sm": ["18px", {"lineHeight": "24px", "fontWeight": "600"}],
                    "body-md": ["16px", {"lineHeight": "24px", "fontWeight": "400"}],
                    "headline-md": ["32px", {"lineHeight": "40px", "fontWeight": "600"}],
                    "body-sm": ["14px", {"lineHeight": "20px", "fontWeight": "400"}],
                    "headline-md-mobile": ["24px", {"lineHeight": "32px", "fontWeight": "600"}],
                    "display-lg": ["48px", {"lineHeight": "56px", "letterSpacing": "-0.02em", "fontWeight": "700"}]
            }
          },
        },
      }
    </script>
<style>
        .material-symbols-outlined {
            font-variation-settings: 'FILL' 0, 'wght' 400, 'GRAD' 0, 'opsz' 24;
            display: inline-block;
            vertical-align: middle;
        }
        body {
            background-color: #f9f9f9;
            color: #1a1c1c;
            -webkit-font-smoothing: antialiased;
        }
        .form-input-minimal {
            border: none;
            border-bottom: 1px solid #e2e2e2;
            background: transparent;
            transition: border-color 0.3s ease;
        }
        .form-input-minimal:focus {
            outline: none;
            border-bottom-color: #000000;
            box-shadow: none;
        }
        .glass-panel {
            background: rgba(255, 255, 255, 0.8);
            backdrop-filter: blur(12px);
            -webkit-backdrop-filter: blur(12px);
        }
    </style>
</head>
<body class="flex flex-col min-h-screen">
<!-- Top Navigation -->
<nav class="fixed top-0 left-0 right-0 z-50 bg-surface dark:bg-surface-container-lowest border-b border-outline-variant dark:border-outline">
<div class="flex justify-between items-center w-full px-margin-desktop max-w-max-width mx-auto h-16">
<div class="flex items-center gap-8">
<a class="font-headline-md text-headline-md font-bold text-primary dark:text-on-primary-fixed" href="#">Chess Academy</a>
<div class="hidden md:flex gap-6">
<a class="text-on-surface-variant dark:text-on-surface-variant font-medium hover:text-primary dark:hover:text-primary-fixed transition-colors duration-200 font-label-mono text-label-mono" href="#">Home</a>
<a class="text-on-surface-variant dark:text-on-surface-variant font-medium hover:text-primary dark:hover:text-primary-fixed transition-colors duration-200 font-label-mono text-label-mono" href="#">How to Play</a>
<a class="text-on-surface-variant dark:text-on-surface-variant font-medium hover:text-primary dark:hover:text-primary-fixed transition-colors duration-200 font-label-mono text-label-mono" href="#">Watch a Tutorial</a>
<a class="text-on-surface-variant dark:text-on-surface-variant font-medium hover:text-primary dark:hover:text-primary-fixed transition-colors duration-200 font-label-mono text-label-mono" href="#">Best Players</a>
</div>
</div>
<div class="flex items-center gap-4">
<button class="font-label-mono text-label-mono text-on-surface-variant hover:text-primary transition-colors">Sign In</button>
<button class="bg-primary text-on-primary px-6 py-2 font-label-mono text-label-mono rounded-lg hover:opacity-80 transition-opacity">Register</button>
</div>
</div>
</nav>
<!-- Main Content Canvas -->
<main class="flex-grow flex items-center justify-center pt-24 pb-12 px-margin-mobile md:px-margin-desktop">
<div class="w-full max-w-4xl grid md:grid-cols-2 gap-12 items-center">
<!-- Branding/Left Column -->
<div class="hidden md:block">
<h1 class="font-display-lg text-display-lg text-primary mb-6 leading-tight">Master the art <br/>of strategy.</h1>
<p class="font-body-md text-body-md text-on-surface-variant mb-12 max-w-sm">
                    Join a community of scholars and grandmasters. Access curated lessons, real-time analysis, and a timeless heritage.
                </p>
<div class="relative w-full aspect-square bg-surface-container rounded-xl overflow-hidden border border-outline-variant">
<img class="w-full h-full object-cover grayscale opacity-90" data-alt="A high-end, minimalist photograph of a single black marble chess king sitting on a white polished surface. The lighting is soft and directional, casting a long, elegant shadow. The overall aesthetic is clean, premium, and intellectual, following an Apple-inspired minimalist design language with high contrast and generous white space." src="https://lh3.googleusercontent.com/aida-public/AB6AXuB1stGMq8m13dWxMWPiD1nfHr_SiffpCs74PZ64LcqNvmeT7kW6Obu5UxkJ1O6GcaofEe4m_8aZ4zWNNxOnqnzod19fe-A6tN8rsiWKGtzo6VQFoXxpNUg7j7ETM3IFhxbJ-re0wfQOcbcKQelpZVepq3r3Tyk0Jz6bxvWXvXJX9m_CfNhPlRq8rLeL6VjjtUdfn3ooTBVSp_eTyHVQxQzn2-oGWl5UWVBNxO32zEV6Hy6h2phsnNC0glcCeBg3TxmPaKxxb7PrGVA"/>
</div>
</div>
<!-- Registration Form Panel -->
<div class="bg-white p-8 md:p-12 rounded-xl border border-outline-variant shadow-sm">
<div class="mb-8 md:hidden">
<h2 class="font-headline-md text-headline-md text-primary">Join the Academy</h2>
</div>
<header class="mb-10 hidden md:block">
<h2 class="font-headline-md text-headline-md text-primary mb-2">Create your account</h2>
<p class="font-body-sm text-body-sm text-on-surface-variant">Already a member? <a class="text-primary font-medium underline underline-offset-4" href="#">Sign in</a></p>
</header>
<form class="space-y-8" onsubmit="event.preventDefault();">
<div class="space-y-1">
<label class="font-label-mono text-label-mono uppercase tracking-wider text-on-surface-variant" for="name">Full Name</label>
<input class="w-full py-3 font-body-md text-body-md form-input-minimal placeholder:text-outline-variant" id="name" name="name" placeholder="Emanuel Lasker" type="text"/>
</div>
<div class="space-y-1">
<label class="font-label-mono text-label-mono uppercase tracking-wider text-on-surface-variant" for="email">Email Address</label>
<input class="w-full py-3 font-body-md text-body-md form-input-minimal placeholder:text-outline-variant" id="email" name="email" placeholder="grandmaster@chessacademy.com" type="email"/>
</div>
<div class="space-y-1">
<label class="font-label-mono text-label-mono uppercase tracking-wider text-on-surface-variant" for="password">Password</label>
<input class="w-full py-3 font-body-md text-body-md form-input-minimal placeholder:text-outline-variant" id="password" name="password" placeholder="••••••••" type="password"/>
<p class="font-label-mono text-[10px] text-on-surface-variant mt-2">Minimum 8 characters with strategy in mind.</p>
</div>
<div class="pt-4">
<button class="w-full bg-primary text-on-primary py-4 font-label-mono text-label-mono uppercase tracking-widest rounded transition-all hover:bg-opacity-90 active:scale-[0.98]" type="submit">
                            Join the Academy
                        </button>
</div>
<div class="flex items-center gap-4 py-2">
<div class="h-[1px] flex-grow bg-outline-variant"></div>
<span class="font-label-mono text-label-mono text-outline-variant">OR</span>
<div class="h-[1px] flex-grow bg-outline-variant"></div>
</div>
<button class="w-full border border-outline-variant text-primary py-4 font-label-mono text-label-mono uppercase tracking-widest rounded flex items-center justify-center gap-2 hover:bg-surface-container transition-colors" type="button">
<span class="material-symbols-outlined text-[18px]">account_balance</span>
                        Sign up with Apple
                    </button>
</form>
<footer class="mt-8">
<p class="font-body-sm text-body-sm text-on-surface-variant text-center leading-relaxed">
                        By joining, you agree to our <a class="underline" href="#">Terms of Service</a> and <a class="underline" href="#">Privacy Policy</a>.
                    </p>
</footer>
</div>
</div>
</main>
<!-- Footer -->
<footer class="w-full py-12 px-margin-desktop max-w-max-width mx-auto flex flex-col md:flex-row justify-between items-center gap-4 border-t border-outline-variant dark:border-outline bg-surface dark:bg-surface-container-low">
<div class="flex flex-col items-center md:items-start gap-2">
<span class="font-headline-md text-headline-md text-primary">Chess Academy</span>
<p class="font-body-sm text-body-sm text-on-surface dark:text-on-surface">© 2024 Chess Academy. All rights reserved.</p>
</div>
<div class="flex gap-8">
<a class="text-on-surface-variant dark:text-on-surface-variant font-label-mono text-label-mono hover:underline transition-all" href="#">About Us</a>
<a class="text-on-surface-variant dark:text-on-surface-variant font-label-mono text-label-mono hover:underline transition-all" href="#">Privacy Policy</a>
<a class="text-on-surface-variant dark:text-on-surface-variant font-label-mono text-label-mono hover:underline transition-all" href="#">Terms of Service</a>
<a class="text-on-surface-variant dark:text-on-surface-variant font-label-mono text-label-mono hover:underline transition-all" href="#">Contact</a>
</div>
</footer>
<script>
        // Micro-interaction: Subtle parallax effect on the image
        document.addEventListener('mousemove', (e) => {
            const imgContainer = document.querySelector('img');
            if (!imgContainer) return;
            const x = (window.innerWidth - e.pageX * 2) / 100;
            const y = (window.innerHeight - e.pageY * 2) / 100;
            imgContainer.style.transform = `translateX(${x}px) translateY(${y}px) scale(1.05)`;
        });

        // Form focus interaction
        const inputs = document.querySelectorAll('.form-input-minimal');
        inputs.forEach(input => {
            input.addEventListener('focus', () => {
                input.parentElement.querySelector('label').classList.add('text-primary');
            });
            input.</script></body></html>