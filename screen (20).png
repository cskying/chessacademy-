<!-- Hero Section -->
<section class="relative min-h-[90vh] flex flex-col items-center justify-center text-center px-margin-mobile md:px-margin-desktop hero-gradient overflow-hidden">
<div class="absolute inset-0 z-0">
<!-- STITCH_THREEJS_START:ANIMATION_8 class="absolute inset-0 w-full h-full grayscale opacity-60" -->
<div class="absolute inset-0 w-full h-full grayscale opacity-60" style="display:block;">
<script src="https://ajax.googleapis.com/ajax/libs/threejs/r125/three.min.js"></script>
<div id="threejs-container-ANIMATION_8" style="width:100%;height:100%"></div>
<script>
(function() {
  const container = document.getElementById('threejs-container-ANIMATION_8');
  const devicePixelRatio = window.devicePixelRatio || 1;
  (function() {
  const container = document.getElementById('threejs-container-ANIMATION_3');
  const width = container.clientWidth || window.innerWidth;
  const height = container.clientHeight || window.innerHeight;

  const scene = new THREE.Scene();
  const camera = new THREE.PerspectiveCamera(75, width / height, 0.1, 1000);
  const renderer = new THREE.WebGLRenderer({ alpha: true, antialias: true });
  renderer.setSize(width, height);
  renderer.setPixelRatio(window.devicePixelRatio);
  container.appendChild(renderer.domElement);

  // Lighting - dramatic high-contrast studio lighting
  const ambientLight = new THREE.AmbientLight(0xffffff, 0.4);
  scene.add(ambientLight);
  const spotLight = new THREE.SpotLight(0xffffff, 1);
  spotLight.position.set(5, 10, 5);
  spotLight.castShadow = true;
  scene.add(spotLight);

  // Create a stylized board
  const boardGeom = new THREE.BoxGeometry(4, 0.1, 4);
  const boardMat = new THREE.MeshPhongMaterial({ color: 0x111111 });
  const board = new THREE.Mesh(boardGeom, boardMat);
  scene.add(board);

  // Stylized Hand/Arm 1 (Black side)
  const arm1Group = new THREE.Group();
  const forearm1Geom = new THREE.CylinderGeometry(0.15, 0.2, 1.5, 32);
  const skinMat = new THREE.MeshPhongMaterial({ color: 0x222222 });
  const forearm1 = new THREE.Mesh(forearm1Geom, skinMat);
  forearm1.rotation.x = Math.PI / 4;
  arm1Group.add(forearm1);
  
  const hand1Geom = new THREE.SphereGeometry(0.2, 32, 32);
  const hand1 = new THREE.Mesh(hand1Geom, skinMat);
  hand1.position.set(0, 0.6, 0.6);
  arm1Group.add(hand1);
  
  arm1Group.position.set(0, 0.5, -2.5);
  scene.add(arm1Group);

  // Stylized Hand/Arm 2 (White side)
  const arm2Group = new THREE.Group();
  const forearm2Geom = new THREE.CylinderGeometry(0.15, 0.2, 1.5, 32);
  const skinMatWhite = new THREE.MeshPhongMaterial({ color: 0xeeeeee });
  const forearm2 = new THREE.Mesh(forearm2Geom, skinMatWhite);
  forearm2.rotation.x = -Math.PI / 4;
  arm2Group.add(forearm2);
  
  const hand2Geom = new THREE.SphereGeometry(0.2, 32, 32);
  const hand2 = new THREE.Mesh(hand2Geom, skinMatWhite);
  hand2.position.set(0, 0.6, -0.6);
  arm2Group.add(hand2);
  
  arm2Group.position.set(0, 0.5, 2.5);
  scene.add(arm2Group);

  // Chess Piece being moved
  const pieceGeom = new THREE.CylinderGeometry(0.15, 0.2, 0.5, 32);
  const pieceMat = new THREE.MeshPhongMaterial({ color: 0x333333 });
  const piece = new THREE.Mesh(pieceGeom, pieceMat);
  piece.position.y = 0.3;
  scene.add(piece);

  camera.position.set(4, 3, 4);
  camera.lookAt(0, 0, 0);

  let time = 0;
  function animate() {
    requestAnimationFrame(animate);
    time += 0.02;

    // Subtle movement of arms/hands to simulate "playing"
    arm1Group.position.x = Math.sin(time) * 0.2;
    arm2Group.position.x = Math.cos(time) * 0.2;
    
    // Move the piece between two positions
    const cycle = (Math.sin(time * 0.5) + 1) / 2;
    piece.position.x = THREE.MathUtils.lerp(-1, 1, cycle);
    piece.position.z = THREE.MathUtils.lerp(-1, 1, cycle);
    piece.position.y = 0.3 + Math.sin(time * 0.5 * Math.PI) * 0.5;

    renderer.render(scene, camera);
  }

  window.addEventListener('resize', () => {
    const w = container.clientWidth || window.innerWidth;
    const h = container.clientHeight || window.innerHeight;
    renderer.setSize(w, h);
    camera.aspect = w / h;
    camera.updateProjectionMatrix();
  });

  animate();
})();
})();
</script>
</div>
<!-- STITCH_THREEJS_END:ANIMATION_8 -->
